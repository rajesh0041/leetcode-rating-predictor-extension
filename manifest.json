{
  "manifest_version": 3,
  "name": "LeetCode Rating Predictor",
  "version": "1.0",
  "description": "Predicts your LeetCode contest rating change directly on the ranking page",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://leetcode.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/contest/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}